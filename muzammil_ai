<!DOCTYPE html>
<html>
<head>
    <title>Muzammil AI</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #202123;
            color: white;
            margin: 0;
        }

        .header {
            background: #343541;
            padding: 15px;
            text-align: center;
            font-size: 28px;
            font-weight: bold;
        }

        .chat-box {
            height: 75vh;
            overflow-y: auto;
            padding: 20px;
        }

        .message {
            margin: 10px 0;
            padding: 12px;
            border-radius: 10px;
        }

        .user {
            background: #444654;
            text-align: right;
        }

        .ai {
            background: #10a37f;
        }

        .input-area {
            display: flex;
            padding: 15px;
            background: #343541;
        }

        input {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
        }

        button {
            margin-left: 10px;
            padding: 12px 20px;
            background: #10a37f;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }
    </style>
</head>
<body>

<div class="header">🤖 Muzammil AI</div>

<div class="chat-box" id="chatBox">
    <div class="message ai">
        Hello! I am Muzammil AI. How can I help you?
    </div>
</div>

<div class="input-area">
    <input type="text" id="userInput" placeholder="Type your message...">
    <button onclick="sendMessage()">Send</button>
</div>

<script>
function sendMessage() {
    let input = document.getElementById("userInput");
    let chatBox = document.getElementById("chatBox");

    if(input.value.trim() === "") return;

    chatBox.innerHTML += `
        <div class="message user">${input.value}</div>
    `;

    let userText = input.value.toLowerCase();

    let reply = "I am Muzammil AI. I am still learning.";

    if(userText.includes("hello")) {
        reply = "Hello! Nice to meet you.";
    }
    else if(userText.includes("how are you")) {
        reply = "I am fine. Thanks for asking!";
    }
    else if(userText.includes("name")) {
        reply = "My name is Muzammil AI.";
    }

    setTimeout(() => {
        chatBox.innerHTML += `
            <div class="message ai">${reply}</div>
        `;
        chatBox.scrollTop = chatBox.scrollHeight;
    }, 500);

    input.value = "";
}
</script>

</body>
</html>
